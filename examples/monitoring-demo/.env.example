# Slack alert integration
# 1. Go to https://api.slack.com/apps and create a new app (or use existing)
# 2. Enable "Incoming Webhooks" under Features
# 3. Click "Add New Webhook to Workspace" and pick a channel
# 4. Copy the webhook URL below
#
# Then: cp .env.example .env  and fill in the URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
