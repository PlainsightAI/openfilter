{
  "id": null,
  "uid": "openfilter-pipeline-monitor",
  "title": "OpenFilter Pipeline Monitor",
  "description": "End-to-end visibility for OpenFilter pipelines: throughput, timing, resources, and health.",
  "tags": [
    "openfilter"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "pipeline_id",
        "label": "Pipeline",
        "type": "custom",
        "query": "p1 (transform-chain) : transform-chain, p2 (fan-out) : fan-out, p3 (diamond) : diamond, p4 (diamond-same-class) : diamond-same-class",
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "p1 (transform-chain)",
            "value": "transform-chain",
            "selected": false
          },
          {
            "text": "p2 (fan-out)",
            "value": "fan-out",
            "selected": false
          },
          {
            "text": "p3 (diamond)",
            "value": "diamond",
            "selected": false
          },
          {
            "text": "p4 (diamond-same-class)",
            "value": "diamond-same-class",
            "selected": false
          }
        ],
        "multi": true,
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Pipelines",
      "description": "Number of distinct pipeline_id values currently reporting metrics.",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "count(count by (pipeline_id)(openfilter_process_time_ms))",
          "legendFormat": "Pipelines",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total FPS",
      "description": "Sum of frames per second across all filters in the selected pipelines.",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 5
              }
            ]
          },
          "decimals": 1
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "sum(videoin_fps{pipeline_id=~\"$pipeline_id\"}) + sum(grayscalefilter_fps{pipeline_id=~\"$pipeline_id\"} or vector(0)) + sum(resizefilter_fps{pipeline_id=~\"$pipeline_id\"} or vector(0)) + sum(timingfilter_fps{pipeline_id=~\"$pipeline_id\"} or vector(0))",
          "legendFormat": "Total FPS",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Camera Connected",
      "description": "1 = source connected, 0 = disconnected (triggers CameraDisconnected alert after 30s).",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DISCONNECTED",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "CONNECTED",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "min(openfilter_camera_connected{pipeline_id=~\"$pipeline_id\"})",
          "legendFormat": "Camera",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Disk Usage %",
      "description": "System disk usage. DiskCriticalTest alert fires above 10%, DiskCritical above 90%.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "orange",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "max(openfilter_disk_usage_percent)",
          "legendFormat": "Disk",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "RAM Usage %",
      "description": "System-level RAM utilization.",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "max(openfilter_ram_usage_percent)",
          "legendFormat": "RAM",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "GPU Accessible",
      "description": "1 = GPU found (nvidia-smi responds). Always 0 on macOS. Triggers GPUUnavailable alert.",
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NO GPU",
                  "color": "orange",
                  "index": 0
                },
                "1": {
                  "text": "GPU OK",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "min(openfilter_gpu_accessible{pipeline_id=~\"$pipeline_id\"})",
          "legendFormat": "GPU",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Throughput",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "FPS per Filter",
      "description": "Frames per second at each filter stage. A drop means the filter is a bottleneck or upstream is stalling. All filters in the same pipeline should run at the same FPS.",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "videoin_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "VideoIn / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "grayscalefilter_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Grayscale / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "resizefilter_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Resize / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "statsfilter_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Stats / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "timingfilter_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Timing / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "slowpassthrough_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "SlowPassthrough / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "webvis_fps{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Webvis / {{filter_id}} ({{pipeline_id}})"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Input / Output Latency (ms)",
      "description": "lat_in = time between a frame being produced upstream and this filter picking it up (queue wait). lat_out = time to emit downstream. High lat_in means this filter cannot keep up.",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "grayscalefilter_lat_in{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Grayscale lat_in / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "resizefilter_lat_in{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Resize lat_in / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "statsfilter_lat_in{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Stats lat_in / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "timingfilter_lat_in{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Timing lat_in / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "slowpassthrough_lat_in{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "SlowPassthrough lat_in / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "grayscalefilter_lat_out{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Grayscale lat_out / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "resizefilter_lat_out{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Resize lat_out / {{filter_id}} ({{pipeline_id}})"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Frames Processed (cumulative counter)",
      "description": "Total frames processed by each filter since startup. All filters in the same pipeline should increase at the same rate. A slower slope means that filter is dropping or skipping frames.",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "grayscalefilter_frame_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Grayscale / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "resizefilter_frame_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Resize / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "statsfilter_frame_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Stats / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "timingfilter_frame_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Timing / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "slowpassthrough_frame_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "SlowPassthrough / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "webvis_frame_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Webvis / {{filter_id}} ({{pipeline_id}})"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Megapixels Processed (cumulative)",
      "description": "Total megapixels processed. Higher resolution sources produce steeper slopes. Useful for estimating GPU/CPU load per pixel.",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "grayscalefilter_megapx_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Grayscale / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "resizefilter_megapx_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Resize / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "statsfilter_megapx_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Stats / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "timingfilter_megapx_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Timing / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "slowpassthrough_megapx_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "SlowPassthrough / {{filter_id}} ({{pipeline_id}})"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "webvis_megapx_count_total{pipeline_id=~\"$pipeline_id\"}",
          "legendFormat": "Webvis / {{filter_id}} ({{pipeline_id}})"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "End-to-End Timing",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Per-Filter Process Time (ms, EMA)",
      "description": "How long each filter's process() call took, smoothed with EMA (alpha=0.05). The tallest line is your bottleneck. In P4 (diamond-same-class), the two SlowPassthrough branches appear as separate lines with distinct filter_ids - that is the Bug 1 fix.",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
