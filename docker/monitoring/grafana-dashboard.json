    {
      "id": 42,
      "type": "table",
      "title": "Firing Alerts",
      "description": "Prometheus alerts currently in FIRING or PENDING state. GPUUnavailable always fires on macOS (no nvidia-smi). PipelineDown fires if any pipeline goes silent for 90s.",
      "gridPos": {
        "x": 12,
        "y": 39,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "openfilter_prometheus"
      },
      "options": {
        "sortBy": [
          {
            "displayName": "State"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "alertstate"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "firing": {
                        "color": "red",
                        "index": 0
                      },
                      "pending": {
                        "color": "yellow",
                        "index": 1
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "openfilter_prometheus"
          },
          "expr": "ALERTS",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "Value": true,
              "job": true,
              "instance": true,
              "otel_scope_name": true,
              "exported_job": true,
              "exported_instance": true
            },
            "indexByName": {
              "alertname": 0,
              "alertstate": 1,
              "severity": 2,
              "pipeline_id": 3,
              "filter_name": 4
            }
          }
        }
      ]
